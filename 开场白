    // ========== 发送消息到酒馆 ==========
    function sendAsUserMessage(messageText) {
        // 方法1：标准 SillyTavern 全局发送函数
        if (typeof window.parent?.sendMessage === 'function') {
            window.parent.sendMessage(messageText);
            return true;
        }
        // 方法2：postMessage 备用
        if (window.parent && window.parent !== window) {
            window.parent.postMessage({
                type: 'sendMessage',
                message: messageText
            }, '*');
            return true;
        }
        // 方法3：降级——复制到剪贴板
        navigator.clipboard?.writeText(messageText).then(() => {
            alert('✅ 开局文本已复制到剪贴板！\n请粘贴到输入框并发送。');
        }).catch(() => {
            prompt('📋 请手动复制以下文本，然后粘贴到输入框发送：', messageText);
        });
        return false;
    }

